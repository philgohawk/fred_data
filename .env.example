# FRED API key from https://fredaccount.stlouisfed.org
FRED_API_KEY=73f2b90838c89cf4dec7c2a4f6dce915

# Snowflake (required) - locator, account.region, or full URL from Snowsight
SNOWFLAKE_ACCOUNT=your_account_locator
SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password

# Required when account is locator-only. Use your region: us-east-1, us-west-2, etc.
SNOWFLAKE_REGION=us-east-1

# Snowflake (optional - defaults shown)
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=FRED
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_TABLE=fred_observations

# Starburst Galaxy (for Streamlit app federated queries)
# Use bare hostname from Partner connect → Trino Python or PyStarburst tile (e.g. your-cluster.trino.galaxy.starburst.io)
STARBURST_HOST=your-cluster.galaxy.starburst.io
STARBURST_USER=your_username/accountadmin
STARBURST_PASSWORD=your_password
